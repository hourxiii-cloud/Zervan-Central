{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "zervan://candidate/v40/contracts/reporting_requirement_inventory/1",
  "title": "Zervan v40 Candidate Reporting Requirement Inventory",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "requirement_inventory_version",
    "requirement_inventory_id",
    "contract_ref",
    "reporting_request_ref",
    "route_ref",
    "inventory_state",
    "requirements",
    "created_at_utc",
    "previous_requirement_inventory_ref",
    "authority_state",
    "human_gate_state",
    "requirement_inventory_sha512"
  ],
  "properties": {
    "requirement_inventory_version": {"const": "v40-candidate.1"},
    "requirement_inventory_id": {
      "type": "string",
      "pattern": "^RRI-[A-Z0-9._-]+$"
    },
    "contract_ref": {"type": "string", "pattern": "^OC-[A-Z0-9._-]+$"},
    "reporting_request_ref": {"type": "string", "minLength": 1},
    "route_ref": {"type": "string", "minLength": 3},
    "inventory_state": {"const": "CLOSED"},
    "requirements": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/requirement"}
    },
    "created_at_utc": {"type": "string", "format": "date-time"},
    "previous_requirement_inventory_ref": {
      "anyOf": [
        {"type": "string", "pattern": "^RRI-[A-Z0-9._-]+$"},
        {"type": "null"}
      ]
    },
    "authority_state": {"const": "NONE"},
    "human_gate_state": {"const": "ACTIVE"},
    "requirement_inventory_sha512": {"$ref": "#/$defs/sha512"}
  },
  "$defs": {
    "sha512": {"type": "string", "pattern": "^[0-9a-f]{128}$"},
    "unique_strings": {
      "type": "array",
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "nonempty_unique_strings": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "ordering_constraint": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "constraint_class",
        "target_refs",
        "sequence_index",
        "description"
      ],
      "properties": {
        "constraint_class": {
          "enum": [
            "FIRST",
            "LAST",
            "BEFORE",
            "AFTER",
            "SEQUENCE",
            "OTHER_DECLARED"
          ]
        },
        "target_refs": {"$ref": "#/$defs/nonempty_unique_strings"},
        "sequence_index": {
          "anyOf": [
            {"type": "integer", "minimum": 1},
            {"type": "null"}
          ]
        },
        "description": {"type": "string", "minLength": 1}
      }
    },
    "completion_test": {
      "type": "object",
      "additionalProperties": false,
      "required": ["test_class", "description", "expected_refs"],
      "properties": {
        "test_class": {
          "enum": [
            "ITEM_PRESENT",
            "CLAIM_CARRIED",
            "ARTIFACT_EXISTS",
            "ORDER_PRESERVED",
            "HASH_VALID",
            "REVIEWABLE",
            "HUMAN_GATE_DECISION",
            "OTHER_DECLARED"
          ]
        },
        "description": {"type": "string", "minLength": 1},
        "expected_refs": {"$ref": "#/$defs/nonempty_unique_strings"}
      }
    },
    "requirement": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "requirement_id",
        "requirement_class",
        "source_class",
        "source_ref",
        "required",
        "description",
        "completion_test",
        "ordering_constraint",
        "artifact_role",
        "claim_or_inventory_refs",
        "status",
        "exclusion_reason",
        "exclusion_ref"
      ],
      "properties": {
        "requirement_id": {"type": "string", "pattern": "^REQ-[A-Z0-9._-]+$"},
        "requirement_class": {
          "enum": [
            "ANALYTICAL_CONTENT",
            "REPORT_ARTIFACT",
            "EVIDENCE_ARTIFACT",
            "METHOD",
            "ORDERING",
            "LIMITATION",
            "PACKAGE",
            "INTEGRITY",
            "STANDALONE_REVIEW",
            "COMPLETION_CRITERION",
            "AUDIENCE",
            "GOVERNANCE",
            "OTHER_DECLARED"
          ]
        },
        "source_class": {
          "enum": [
            "USER_EXPLICIT",
            "OPERATIONAL_CONTRACT",
            "ROUTE_REQUIRED",
            "ANALYTICAL_ESTABLISHED",
            "GOVERNANCE_REQUIRED",
            "HUMAN_GATE_DECISION"
          ]
        },
        "source_ref": {"type": "string", "minLength": 1},
        "required": {"type": "boolean"},
        "description": {"type": "string", "minLength": 1},
        "completion_test": {"$ref": "#/$defs/completion_test"},
        "ordering_constraint": {
          "anyOf": [
            {"$ref": "#/$defs/ordering_constraint"},
            {"type": "null"}
          ]
        },
        "artifact_role": {
          "enum": [
            "CORE_REPORT",
            "EVIDENCE",
            "PROVENANCE",
            "MANIFEST",
            "README",
            "GRAPH",
            "DATA_TABLE",
            "CONTROL_MAPPING",
            "POAM",
            "LIMITATION",
            "PACKAGE",
            "NOT_APPLICABLE",
            "OTHER_DECLARED"
          ]
        },
        "claim_or_inventory_refs": {"$ref": "#/$defs/unique_strings"},
        "status": {
          "enum": [
            "ACTIVE",
            "BLOCKED_UNAVAILABLE",
            "EXPLICITLY_EXCLUDED",
            "UNKNOWN"
          ]
        },
        "exclusion_reason": {
          "anyOf": [
            {"type": "string", "minLength": 1},
            {"type": "null"}
          ]
        },
        "exclusion_ref": {
          "anyOf": [
            {"type": "string", "minLength": 1},
            {"type": "null"}
          ]
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {"requirement_class": {"const": "ORDERING"}},
            "required": ["requirement_class"]
          },
          "then": {
            "properties": {
              "ordering_constraint": {"$ref": "#/$defs/ordering_constraint"}
            }
          }
        },
        {
          "if": {
            "properties": {"status": {"const": "EXPLICITLY_EXCLUDED"}},
            "required": ["status"]
          },
          "then": {
            "properties": {
              "required": {"const": false},
              "exclusion_reason": {"type": "string", "minLength": 1},
              "exclusion_ref": {"type": "string", "minLength": 1}
            }
          },
          "else": {
            "properties": {
              "exclusion_reason": {"type": "null"},
              "exclusion_ref": {"type": "null"}
            }
          }
        }
      ]
    }
  }
}
