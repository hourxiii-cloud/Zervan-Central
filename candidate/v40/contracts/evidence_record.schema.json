{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "zervan://candidate/v40/contracts/evidence_record/1",
  "title": "Zervan v40 Candidate Evidence Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "evidence_version",
    "evidence_id",
    "evidence_class",
    "source_ref",
    "source_object_ref",
    "source_sha512",
    "source_sha512_state",
    "source_sha512_reason",
    "object_ref",
    "value_ref",
    "content_ref",
    "scope",
    "observation_time_utc",
    "observation_time_unknown_reason",
    "source_time_utc",
    "source_time_unknown_reason",
    "acquired_at_utc",
    "reliability_state",
    "limitations",
    "provenance_refs",
    "authority_state",
    "human_gate_state",
    "evidence_sha512"
  ],
  "properties": {
    "evidence_version": {"const": "v40-candidate.1"},
    "evidence_id": {"type": "string", "pattern": "^EV-[A-Z0-9._-]+$"},
    "evidence_class": {
      "enum": [
        "SOURCE_ASSERTION",
        "OBSERVATION",
        "MEASUREMENT",
        "DERIVED_MEASUREMENT",
        "DOCUMENT",
        "DATASET_OBJECT",
        "WORKBOOK_OBJECT",
        "TRANSITION_WITNESS",
        "SCAR",
        "REPLAY_RECEIPT",
        "OTHER_DECLARED"
      ]
    },
    "source_ref": {"type": "string", "minLength": 1},
    "source_object_ref": {
      "anyOf": [
        {"type": "string", "minLength": 1},
        {"type": "null"}
      ]
    },
    "source_sha512": {
      "anyOf": [
        {"$ref": "#/$defs/sha512"},
        {"type": "null"}
      ]
    },
    "source_sha512_state": {
      "enum": ["AVAILABLE", "UNAVAILABLE", "UNKNOWN", "NOT_APPLICABLE"]
    },
    "source_sha512_reason": {
      "anyOf": [
        {"type": "string", "minLength": 1},
        {"type": "null"}
      ]
    },
    "object_ref": {"type": "string", "minLength": 1},
    "value_ref": {
      "anyOf": [
        {"type": "string", "minLength": 1},
        {"type": "null"}
      ]
    },
    "content_ref": {
      "anyOf": [
        {"type": "string", "minLength": 1},
        {"type": "null"}
      ]
    },
    "scope": {"type": "string", "minLength": 1},
    "observation_time_utc": {"$ref": "#/$defs/nullable_time"},
    "observation_time_unknown_reason": {
      "anyOf": [
        {"type": "string", "minLength": 1},
        {"type": "null"}
      ]
    },
    "source_time_utc": {"$ref": "#/$defs/nullable_time"},
    "source_time_unknown_reason": {
      "anyOf": [
        {"type": "string", "minLength": 1},
        {"type": "null"}
      ]
    },
    "acquired_at_utc": {"type": "string", "format": "date-time"},
    "reliability_state": {
      "enum": [
        "CORROBORATED",
        "SOURCE_REPORTED",
        "PARTIAL",
        "CONTRADICTED",
        "UNRELIABLE",
        "UNKNOWN",
        "NOT_ASSESSED"
      ]
    },
    "limitations": {"$ref": "#/$defs/unique_strings"},
    "provenance_refs": {"$ref": "#/$defs/nonempty_unique_strings"},
    "authority_state": {"const": "NONE"},
    "human_gate_state": {"const": "ACTIVE"},
    "evidence_sha512": {"$ref": "#/$defs/sha512"}
  },
  "allOf": [
    {
      "if": {
        "properties": {"source_sha512_state": {"const": "AVAILABLE"}},
        "required": ["source_sha512_state"]
      },
      "then": {
        "properties": {
          "source_sha512": {"$ref": "#/$defs/sha512"},
          "source_sha512_reason": {"type": "null"}
        }
      },
      "else": {
        "properties": {
          "source_sha512": {"type": "null"},
          "source_sha512_reason": {"type": "string", "minLength": 1}
        }
      }
    },
    {
      "if": {
        "properties": {"observation_time_utc": {"type": "null"}},
        "required": ["observation_time_utc"]
      },
      "then": {
        "properties": {
          "observation_time_unknown_reason": {"type": "string", "minLength": 1}
        }
      },
      "else": {
        "properties": {"observation_time_unknown_reason": {"type": "null"}}
      }
    },
    {
      "if": {
        "properties": {"source_time_utc": {"type": "null"}},
        "required": ["source_time_utc"]
      },
      "then": {
        "properties": {
          "source_time_unknown_reason": {"type": "string", "minLength": 1}
        }
      },
      "else": {
        "properties": {"source_time_unknown_reason": {"type": "null"}}
      }
    }
  ],
  "anyOf": [
    {"properties": {"value_ref": {"type": "string", "minLength": 1}}},
    {"properties": {"content_ref": {"type": "string", "minLength": 1}}}
  ],
  "$defs": {
    "sha512": {"type": "string", "pattern": "^[0-9a-f]{128}$"},
    "nullable_time": {
      "anyOf": [
        {"type": "string", "format": "date-time"},
        {"type": "null"}
      ]
    },
    "unique_strings": {
      "type": "array",
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "nonempty_unique_strings": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    }
  }
}
