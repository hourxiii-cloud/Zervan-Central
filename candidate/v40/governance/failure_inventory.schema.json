{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://zervan.invalid/candidate/v40/governance/failure_inventory.schema.json",
  "title": "Zervan v40 Candidate Failure Inventory",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "candidate_state",
    "authority_state",
    "human_gate",
    "operation",
    "identifier_taxonomy",
    "parent_finding_id",
    "findings"
  ],
  "properties": {
    "schema_version": {"const": "v40-candidate.1"},
    "candidate_state": {"const": "CANDIDATE_ONLY"},
    "authority_state": {"const": "NONE"},
    "human_gate": {"const": "ACTIVE"},
    "operation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "state", "priority_basis"],
      "properties": {
        "id": {"const": "P0"},
        "name": {"const": "Zervan Production Route Failure"},
        "state": {"enum": ["OPEN", "CONTROL_IMPLEMENTED", "VERIFIED", "HUMAN_GATE_REVIEW", "CLOSED"]},
        "priority_basis": {"const": "architectural_impact_and_dependency_not_chronology"}
      }
    },
    "identifier_taxonomy": {
      "const": "P0 identifies the single parent failure operation; Critical, High, and Medium identify individual finding severity. P0 does not encode individual finding priority."
    },
    "parent_finding_id": {"const": "P0-040"},
    "findings": {
      "type": "array",
      "minItems": 40,
      "maxItems": 40,
      "items": {"$ref": "#/$defs/finding"}
    }
  },
  "$defs": {
    "finding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "severity", "title", "implementation_wave", "primary_control", "acceptance_evidence", "state"],
      "properties": {
        "id": {"type": "string", "pattern": "^P0-(00[1-9]|0[1-3][0-9]|040)$"},
        "severity": {"enum": ["Critical", "High", "Medium"]},
        "title": {"type": "string", "minLength": 3},
        "implementation_wave": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "integer", "minimum": 0, "maximum": 5}},
        "primary_control": {"type": "string", "minLength": 10},
        "acceptance_evidence": {"type": "string", "minLength": 10},
        "state": {"enum": ["OPEN", "CONTROL_IMPLEMENTED", "VERIFIED", "HUMAN_GATE_REVIEW", "CLOSED"]}
      }
    }
  }
}
